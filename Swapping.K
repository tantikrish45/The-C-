#include<stdio.h>
main()
 {  
   int a, b;
 printf("Enter no of A : ");
 scanf("%d", &a);
 printf("Your Number of A : %d\n\n" , a);
 printf("Enter no of B : ");
 scanf("%d", &b);
 printf("Your Number of B : %d\n\n" , b);
 printf("Caculat of A  : %d\n", a=a+b);
 printf("Caculat of B  : %d\n", b=a-b);
 printf("Caculat of A  : %d\n\n\n", a=a-b);
 
 printf ("final Number A : %d\n",a);
 printf ("final Number B : %d\n",b);
 
 }
